# Database
DATABASE_URL="postgresql://creatorhub:creatorhub@localhost:5432/creatorhub"

# Environment
NODE_ENV=development

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_PORT=6379

# Storage Provider: "r2" | "s3" | "minio" Change to "s3" for AWS S3, or "r2" for Cloudflare R2, or "minio" for local MinIO. Make sure to set the corresponding credentials below based on your choice.
STORAGE_PROVIDER="minio"

# AWS S3 (uncomment below and use STORAGE_PROVIDER="s3")
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET="creatorhub-assets"

# MinIO for local dev (uncomment below and use STORAGE_PROVIDER="minio")
# AWS_ACCESS_KEY_ID="minioadmin"
# AWS_SECRET_ACCESS_KEY="minioadmin"
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET="creatorhub-assets"
# AWS_S3_ENDPOINT="http://localhost:9000"

# Cloudflare R2 (use STORAGE_PROVIDER="r2")
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="creatorhub-assets"
R2_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"  # REQUIRED for r2

# Auth
JWT_SECRET="change-me-in-production"
JWT_EXPIRATION="7d"

# AI Providers
SILICONFLOW_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""
FLUX_API_KEY=""
STABILITY_AI_API_KEY=""
IDEOGRAM_API_KEY=""

# Speech-to-Text (Deepgram) — https://console.deepgram.com ($200 free credit)
DEEPGRAM_API_KEY=""

# App
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3003"
API_URL="http://localhost:4000"
FRONTEND_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3003"
CYPRESS_INSTALL_BINARY=0

# MercadoPago (Payment Gateway)
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_WEBHOOK_SECRET=""
NEXT_PUBLIC_MP_PUBLIC_KEY=""
# MP_NOTIFICATION_URL="" # Optional - defaults to ${API_URL}/api/v1/webhooks/mercado-pago

RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# X (Twitter) OAuth 2.0 PKCE
# Get credentials from: https://developer.x.com/en/portal/dashboard
X_CLIENT_ID=""
X_CLIENT_SECRET=""
X_REDIRECT_URI="http://localhost:4000/api/v1/social/x/callback"

# Encryption key for OAuth tokens (generate with: openssl rand -hex 32)
X_SOCIAL_ENCRYPTION_KEY=""

# Apify (for X trend research)
APIFY_API_TOKEN=""
#demo development
APIFY_TWITTER_ACTOR_ID="apidojo/twitter-scraper-lite"