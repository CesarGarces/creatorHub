<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin:0; padding:0; background:#0a0a0f; font-family:system-ui,-apple-system,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="padding:40px 20px;">
    <tr>
      <td align="center">
        <table width="480" cellpadding="0" cellspacing="0" style="background:#14141f; border-radius:16px; border:1px solid rgba(255,255,255,0.06); padding:48px 40px;">
          <!-- Header -->
          <tr>
            <td align="center" style="padding-bottom:24px;">
              <div style="width:56px; height:56px; background:linear-gradient(135deg, #ff4444, #ff6b6b); border-radius:14px; margin:0 auto; line-height:56px; text-align:center;">
                <span style="font-size:28px;">&#10007;</span>
              </div>
            </td>
          </tr>
          <tr>
            <td align="center" style="padding-bottom:8px;">
              <h1 style="color:#f0f0f5; font-size:24px; margin:0;">Payment could not be processed</h1>
            </td>
          </tr>
          <tr>
            <td align="center" style="padding-bottom:32px;">
              {{#if userName}}
              <p style="color:#8888a0; font-size:14px; margin:0;">Hi {{userName}}, we were unable to complete your purchase.</p>
              {{else}}
              <p style="color:#8888a0; font-size:14px; margin:0;">We were unable to complete your purchase.</p>
              {{/if}}
            </td>
          </tr>

          <!-- Error Info -->
          <tr>
            <td style="padding-bottom:24px;">
              <table width="100%" cellpadding="0" cellspacing="0" style="background:#1a1a2e; border-radius:12px; padding:24px; border:1px solid rgba(255,68,68,0.15);">
                <tr>
                  <td style="padding-bottom:12px;">
                    <span style="color:#ff6b6b; font-size:14px; font-weight:600;">What happened?</span>
                  </td>
                </tr>
                <tr>
                  <td>
                    {{#if reason}}
                    <p style="color:#8888a0; font-size:13px; margin:0;">{{reason}}</p>
                    {{else}}
                    <p style="color:#8888a0; font-size:13px; margin:0;">Your payment was declined or could not be verified. No charges were made to your account.</p>
                    {{/if}}
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Troubleshooting -->
          <tr>
            <td style="padding-bottom:24px;">
              <table width="100%" cellpadding="0" cellspacing="0" style="background:#1a1a2e; border-radius:12px; padding:20px 24px; border:1px solid rgba(255,255,255,0.04);">
                <tr>
                  <td style="padding-bottom:12px;">
                    <span style="color:#f0f0f5; font-size:14px; font-weight:600;">Troubleshooting tips</span>
                  </td>
                </tr>
                <tr>
                  <td style="padding:4px 0;">
                    <table cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="width:6px;"><div style="width:6px; height:6px; background:#ff6b6b; border-radius:50%;"></div></td>
                        <td style="padding-left:10px;"><span style="color:#c0c0d0; font-size:13px;">Check that your card details are correct</span></td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding:4px 0;">
                    <table cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="width:6px;"><div style="width:6px; height:6px; background:#ff6b6b; border-radius:50%;"></div></td>
                        <td style="padding-left:10px;"><span style="color:#c0c0d0; font-size:13px;">Ensure you have sufficient funds</span></td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding:4px 0;">
                    <table cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="width:6px;"><div style="width:6px; height:6px; background:#ff6b6b; border-radius:50%;"></div></td>
                        <td style="padding-left:10px;"><span style="color:#c0c0d0; font-size:13px;">Try a different payment method</span></td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding:4px 0;">
                    <table cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="width:6px;"><div style="width:6px; height:6px; background:#ff6b6b; border-radius:50%;"></div></td>
                        <td style="padding-left:10px;"><span style="color:#c0c0d0; font-size:13px;">Contact your bank if the issue persists</span></td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- CTA Button -->
          <tr>
            <td align="center" style="padding-bottom:24px;">
              {{#if retryUrl}}
              <a href="{{retryUrl}}" style="background:#00bbd9; color:#ffffff; font-size:15px; font-weight:600; text-decoration:none; padding:14px 36px; border-radius:8px; display:inline-block;">Try Again</a>
              {{else}}
              <a href="https://app.creatorhubplatform.com/credits" style="background:#00bbd9; color:#ffffff; font-size:15px; font-weight:600; text-decoration:none; padding:14px 36px; border-radius:8px; display:inline-block;">Try Again</a>
              {{/if}}
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="border-top:1px solid rgba(255,255,255,0.06); padding-top:24px;">
              <p style="color:#444460; font-size:11px; margin:0;">No charges were made. If you continue to experience issues, please contact support.</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>