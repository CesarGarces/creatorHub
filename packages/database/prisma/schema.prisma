generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SocialResearchSession {
  id        String                  @id @default(cuid())
  userId    String
  toolId    String
  title     String?
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  messages  SocialResearchMessage[]
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, toolId])
  @@index([userId])
}

model SocialResearchMessage {
  id          String                @id @default(cuid())
  sessionId   String
  role        String
  content     String
  resultData  Json?
  provider    String?
  creditsUsed Int                   @default(0)
  cacheHit    Boolean               @default(false)
  createdAt   DateTime              @default(now())
  session     SocialResearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, createdAt])
}

model TrendCache {
  id         String   @id @default(cuid())
  queryHash  String
  provider   String
  resultData Json
  expiresAt  DateTime
  hitCount   Int      @default(0)
  createdAt  DateTime @default(now())

  @@unique([queryHash, provider])
  @@index([queryHash, provider])
  @@index([expiresAt])
}

model User {
  id                   String                  @id @default(cuid())
  email                String                  @unique
  name                 String?
  passwordHash         String?
  avatarUrl            String?
  role                 UserRole                @default(USER)
  isActive             Boolean                 @default(true)
  lastLoginAt          DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  plan                 UserPlan                @default(FREE)
  currentCredits       Int                     @default(100)
  purchasedCredits     Int                     @default(0)
  emailVerified        DateTime?
  verificationCode     String?
  verificationExpires  DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  accounts             Account[]
  apiKeys              ApiKey[]
  assetLikes           AssetLike[]
  chatSessions         ChatSession[]
  chatSettings         ChatSettings?
  creditTxns           CreditTransaction[]
  images               GeneratedImage[]
  marketingEvents      MarketingEvent[]
  notifications        Notification[]
  sessions             Session[]
  socialAccounts       SocialAccount[]
  researchSessions     SocialResearchSession[]
  subscriptions        Subscription[]
  toolAccess           ToolAccess[]
  toolFavorites        ToolFavorite[]
  tweetDrafts          TweetDraft[]
  usageLogs            UsageLog[]
  contentSamples       UserContentSample[]
  styleProfile         UserStyleProfile?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  refreshToken      String?
  accessToken       String?
  expiresAt         Int?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  name      String
  key       String    @unique
  lastUsed  DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Mode {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  description String?
  icon        String?
  color       String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tools       ToolMode[]
  providers   ProviderMode[]
}

model ToolMode {
  id        String   @id @default(cuid())
  toolId    String
  modeId    String
  createdAt DateTime @default(now())
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  mode      Mode     @relation(fields: [modeId], references: [id], onDelete: Cascade)

  @@unique([toolId, modeId])
  @@index([toolId])
  @@index([modeId])
}

model ProviderMode {
  id         String   @id @default(cuid())
  providerId String
  modeId     String
  createdAt  DateTime @default(now())
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  mode       Mode     @relation(fields: [modeId], references: [id], onDelete: Cascade)

  @@unique([providerId, modeId])
  @@index([providerId])
  @@index([modeId])
}

model Tool {
  id              String              @id
  name            String
  description     String
  version         String              @default("1.0.0")
  icon            String?
  category        String
  creditsPerUse   Int                 @default(10)
  status          String              @default("active")
  configSchema    Json?
  manifestVersion String              @default("1.0")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  creditTxns      CreditTransaction[]
  images          GeneratedImage[]
  toolAccess      ToolAccess[]
  toolConfigs     ToolConfig?
  usageLogs       UsageLog[]
  modes           ToolMode[]
}

model ToolConfig {
  id                String   @id @default(cuid())
  toolId            String   @unique
  enabled           Boolean  @default(true)
  creditsPerUse     Int
  maxUsesPerDay     Int?
  allowedRoles      String[] @default([])
  providerOverrides Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tool              Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
}

model ToolAccess {
  id        String   @id @default(cuid())
  userId    String
  toolId    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, toolId])
}

model ToolFavorite {
  id        String   @id @default(cuid())
  userId    String
  toolId    String
  createdAt DateTime @default(now())
  sortOrder Int      @default(0)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, toolId])
  @@index([toolId])
  @@index([userId, sortOrder])
}

model CreditTransaction {
  id          String                @id @default(cuid())
  userId      String
  amount      Int
  type        CreditTransactionType
  description String
  toolId      String?
  provider    String?
  referenceId String?
  balance     Int
  createdAt   DateTime              @default(now())
  tool        Tool?                 @relation(fields: [toolId], references: [id])
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditPlan {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  description  String?
  usdAmount    Float
  creditsGiven Int
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  planId               String
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  creditsThisPeriod    Int                @default(0)
  cancelAtPeriodEnd    Boolean            @default(false)
  stripeSubscriptionId String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  plan                 SubscriptionPlan   @relation(fields: [planId], references: [id])
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SubscriptionPlan {
  id              String         @id @default(cuid())
  name            String
  description     String?
  price           Int
  creditsPerMonth Int
  features        String[]
  tools           String[]
  stripePriceId   String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  subscriptions   Subscription[]
}

model UsageLog {
  id        String   @id @default(cuid())
  userId    String
  toolId    String
  credits   Int
  duration  Int?
  success   Boolean  @default(true)
  error     String?
  metadata  Json?
  createdAt DateTime @default(now())
  tool      Tool     @relation(fields: [toolId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model AIProviderConfig {
  id        String   @id @default(cuid())
  name      String   @unique
  isEnabled Boolean  @default(true)
  priority  Int      @default(0)
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Provider {
  id             String           @id @default(cuid())
  slug           String           @unique
  name           String
  model          String
  tier           ProviderTier     @default(FREE)
  costPerCredit  Int              @default(1)
  isActive       Boolean          @default(true)
  supportedTasks String[]         @default(["thumbnail"])
  config         Json?

  // Gateway support (for OpenRouter, SiliconFlow, etc.)
  isGateway      Boolean          @default(false)
  gatewayConfig  Json?            // { baseUrl, headers, etc. }

  // Sync metadata
  lastSyncAt     DateTime?
  syncStatus     String?          // "syncing" | "success" | "error"

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  images         GeneratedImage[]
  modes          ProviderMode[]
}

// ============================================================
// MODEL METADATA - Centralized model registry for AI providers
// ============================================================
model ModelMetadata {
  id                String   @id @default(cuid())
  providerSlug      String   // "openrouter", "siliconflow"
  modelId           String   // "google/gemini-3.1-flash-image"
  displayName       String   // "Gemini 3.1 Flash Image"
  taskType          String   // "image-generation", "chat", "video-generation"
  tier              ProviderTier @default(PRO)

  // Model capabilities
  contextLength     Int?
  maxOutputTokens   Int?
  supportsStreaming Boolean  @default(false)
  supportsVision    Boolean  @default(false)

  // Pricing (from provider API, USD)
  promptPricePer1k      Float?
  completionPricePer1k  Float?
  imagePricePerGen      Float?

  // Rate limits
  requestsPerMinute Int?
  tokensPerMinute   Int?

  // Admin configuration
  isActive          Boolean  @default(false)
  creditCost        Int      @default(10)
  profitMargin      Float    @default(2.0)

  // Metadata
  description       String?
  tags              String[]
  lastSyncedAt      DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([providerSlug, modelId])
  @@index([taskType, isActive])
  @@index([tier, isActive])
  @@index([providerSlug, isActive])
}

// ============================================================
// PROVIDER USAGE - Cost tracking per model per day
// ============================================================
model ProviderUsage {
  id                String   @id @default(cuid())
  providerSlug      String
  modelId           String
  date              DateTime @db.Date

  // Usage metrics
  totalRequests     Int      @default(0)
  totalTokens       Int      @default(0)
  totalImages       Int      @default(0)

  // Cost tracking
  actualCostUsd     Float    @default(0)   // What we pay to provider
  creditsCharged    Int      @default(0)   // What we charge users

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([providerSlug, modelId, date])
  @@index([date])
  @@index([providerSlug, date])
}

model AIRequestLog {
  id        String   @id @default(cuid())
  userId    String?
  toolId    String?
  provider  String
  model     String
  taskType  String
  prompt    String
  response  Json?
  credits   Int
  latency   Int
  success   Boolean  @default(true)
  error     String?
  createdAt DateTime @default(now())
}

model File {
  id           String           @id @default(cuid())
  userId       String?
  toolId       String?
  originalName String
  mimeType     String
  size         Int
  key          String           @unique
  url          String
  width        Int?
  height       Int?
  duration     Int?
  metadata     Json?
  createdAt    DateTime         @default(now())
  images       GeneratedImage[]
}

model GeneratedImage {
  id              String             @id @default(cuid())
  userId          String
  toolId          String?
  fileId          String?
  prompt          String
  negativePrompt  String?
  provider        String
  model           String
  width           Int
  height          Int
  url             String
  credits         Int
  metadata        Json?
  isPublic        Boolean            @default(false)
  createdAt       DateTime           @default(now())
  storageProvider String             @default("r2")
  isProModel      Boolean            @default(false)
  providerId      String?
  type            GeneratedAssetType @default(IMAGE)
  likeCount       Int                @default(0)
  viewCount       Int                @default(0)
  likes           AssetLike[]
  file            File?              @relation(fields: [fileId], references: [id])
  providerRef     Provider?          @relation(fields: [providerId], references: [id])
  tool            Tool?              @relation(fields: [toolId], references: [id])
  user            User               @relation(fields: [userId], references: [id])
}

model AssetLike {
  id          String         @id @default(cuid())
  assetId     String
  fingerprint String
  userId      String?
  createdAt   DateTime       @default(now())
  asset       GeneratedImage @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user        User?          @relation(fields: [userId], references: [id])

  @@unique([assetId, fingerprint])
  @@index([assetId])
  @@index([fingerprint])
  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, readAt])
  @@index([createdAt])
}

model MarketingEvent {
  id        String             @id @default(cuid())
  userId    String
  type      MarketingEventType
  credits   Int
  metadata  Json?
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id          String        @id @default(cuid())
  userId      String
  title       String?
  model       String        @default("zai-org/GLM-5.2")
  temperature Float         @default(0.7)
  maxTokens   Int           @default(8000)
  reasoning   Float         @default(0.7)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  messages    ChatMessage[]
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ChatMessage {
  id         String      @id @default(cuid())
  sessionId  String
  role       String
  content    String
  toolCalls  Json?
  tokensUsed Int?
  createdAt  DateTime    @default(now())
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model ChatSettings {
  id           String   @id @default(cuid())
  userId       String   @unique
  defaultModel String   @default("zai-org/GLM-5.2")
  temperature  Float    @default(0.7)
  maxTokens    Int      @default(8000)
  reasoning    Float    @default(0.7)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserContentSample {
  id        String              @id @default(cuid())
  userId    String
  content   String
  source    ContentSampleSource @default(MANUAL)
  metadata  Json?
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isActive])
}

model UserStyleProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  tone           String
  vocabKeywords  String[]  @default([])
  sentenceLength String    @default("medium")
  emojiUsage     String    @default("moderate")
  formalityLevel String    @default("casual")
  summary        String?
  sampleCount    Int       @default(0)
  isActive       Boolean   @default(true)
  lastAnalyzedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  language       String    @default("es")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SocialAccount {
  id               String              @id @default(cuid())
  userId           String
  provider         SocialProvider
  providerUserId   String
  providerUsername String?
  displayName      String?
  avatarUrl        String?
  accessToken      String
  refreshToken     String?
  tokenExpiresAt   DateTime?
  scopes           String[]            @default([])
  status           SocialAccountStatus @default(ACTIVE)
  metadata         Json?
  lastUsedAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  tweetDrafts      TweetDraft[]

  @@unique([userId, provider])
  @@index([userId])
  @@index([provider, status])
}

model TweetDraft {
  id               String           @id @default(cuid())
  userId           String
  socialAccountId  String?
  content          String
  topic            String?
  researchData     Json?
  styleProfileId   String?
  status           TweetDraftStatus @default(DRAFT)
  publishedTweetId String?
  publishedAt      DateTime?
  metadata         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  socialAccount    SocialAccount?   @relation(fields: [socialAccountId], references: [id])
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, status])
}

enum UserRole {
  USER
  PREMIUM
  ADMIN
}

enum UserPlan {
  FREE
  PAY_AS_YOU_GO
  PREMIUM
  STARTER
  PRO
}

enum CreditTransactionType {
  PURCHASE
  USAGE
  REFUND
  BONUS
  SUBSCRIPTION
  PROMOTION
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  EXPIRED
  TRIALING
}

enum ProviderTier {
  FREE
  PRO
}

enum GeneratedAssetType {
  IMAGE
  VIDEO
}

enum NotificationType {
  CREDIT_LOW
  CREDIT_ADDED
  IMAGE_READY
  TOOL_NEW
  SUBSCRIPTION_EXPIRING
  SYSTEM
  ASSET_LIKE
}

enum MarketingEventType {
  CREDIT_THRESHOLD_75
  CREDIT_THRESHOLD_25
  CREDIT_THRESHOLD_10
  CREDIT_THRESHOLD_5
  CREDIT_DEPLETED
  CREDIT_EXHAUSTED
  FIRST_GENERATION
  UPGRADE_PROMPT
  REENGAGEMENT
}

enum ContentSampleSource {
  MANUAL
  CHAT
  TWEET
  POST
  IMPORT
}

enum SocialProvider {
  X_TWITTER
  YOUTUBE
  TWITCH
  INSTAGRAM
  TIKTOK
}

enum SocialAccountStatus {
  ACTIVE
  EXPIRED
  REVOKED
  ERROR
}

enum TweetDraftStatus {
  DRAFT
  PREVIEW
  PUBLISHED
  FAILED
  CANCELLED
}
